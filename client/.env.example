# API Base URL for backend requests.
# - If left empty or using '/api', it will proxy requests to http://localhost:5001 in development,
#   and use relative paths in production (when served by the backend or a proxy).
# - Set to a full URL (e.g. http://localhost:5001/api or https://api.example.com/api) if
#   the frontend is deployed separately from the backend.
VITE_API_BASE=/api
