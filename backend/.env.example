# Backend Server Environment Variables

# The port to run the express server on (default: 5001)
PORT=5001

# Environment mode (development or production)
NODE_ENV=development

# MongoDB Connection string
MONGO_URI=mongodb://localhost:27017/ai_helpdesk

# Secret key for signing JSON Web Tokens (JWT)
JWT_SECRET=replace_with_a_secure_random_string_in_production

# OpenAI API Key (optional fallback heuristic is used if omitted)
# OPENAI_API_KEY=your-openai-api-key
