# Backend Server Environment Variables

# The port to run the express server on (default: 5001)
PORT=5001

# Environment mode (development or production)
NODE_ENV=development

# MongoDB Connection string
MONGO_URI=mongodb://localhost:27017/ai_helpdesk

# Secret key for signing JSON Web Tokens (JWT)
JWT_SECRET=replace_with_a_secure_random_string_in_production

# OpenAI API Key (optional fallback heuristic is used if omitted)
# OPENAI_API_KEY=your-openai-api-key

# Allowed frontend origin for CORS (defaults to * if not set)
# In production, set this to your Vercel frontend URL e.g. https://ai-helpdesk.vercel.app
# In development, leave as http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Set to 'true' ONLY if deploying as a monolith (backend serves client/dist).
# Leave unset (or 'false') when frontend is deployed separately on Vercel.
# SERVE_STATIC=true